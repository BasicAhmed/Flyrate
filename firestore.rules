rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rates/{corridor} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /sales/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
